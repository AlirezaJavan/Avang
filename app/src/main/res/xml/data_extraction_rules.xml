<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- Cloud backup (Google Drive) -->
    <cloud-backup>
        <include domain="database" path="music-database" />
        <include domain="database" path="music-database-shm" />
        <include domain="database" path="music-database-wal" />
        <include domain="file" path="datastore/user_preferences.preferences_pb" />
    </cloud-backup>

    <!-- Device-to-device transfer (e.g. phone upgrade) -->
    <device-transfer>
        <include domain="database" path="music-database" />
        <include domain="database" path="music-database-shm" />
        <include domain="database" path="music-database-wal" />
        <include domain="file" path="datastore/user_preferences.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
